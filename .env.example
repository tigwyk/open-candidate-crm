# SQLite database file
DATABASE_URL="file:./db/custom.db"

# Auth (Phase 1 — single-operator credential, no User table)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-base64-secret"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_EMAIL="admin@example.com"
# bcrypt hash of the admin password. Next.js expands $VAR syntax in .env files,
# so every literal `$` in the hash must be escaped as `\$` or it gets mangled.
# Generate an already-escaped value with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10).split('$').join('\\$'))"
ADMIN_PASSWORD_HASH="\$2b\$10\$replace.with.an.escaped.bcrypt.hash"
