# Postgres connection string. Matches the `docker-compose.yml` postgres
# service out of the box — `docker compose up -d` and this just works.
# Railway auto-injects this as a reference variable once the Postgres plugin
# is linked to this service, overriding the local value in production.
DATABASE_URL="postgresql://campaignground:campaignground@localhost:55432/campaignground"

# Auth (Phase 1 — single-operator credential, no User table)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-base64-secret"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_EMAIL="admin@example.com"
# bcrypt hash of the admin password. Next.js expands $VAR syntax in .env files,
# so every literal `$` in the hash must be escaped as `\$` or it gets mangled.
# Generate an already-escaped value with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10).split('$').join('\\$'))"
ADMIN_PASSWORD_HASH="\$2b\$10\$replace.with.an.escaped.bcrypt.hash"

# Signup (open self-service, /signup). Optional cap on total accounts —
# leave unset for unlimited (default).
# MAX_USERS="500"

# Postmark (transactional email for team invites). Leave unset in dev to log
# invite links to the console instead of sending real email.
POSTMARK_SERVER_TOKEN=""
EMAIL_FROM="CampaignGround <invites@yourdomain.com>"

# Postmark bounce webhook Basic Auth. Configure the webhook URL in Postmark's
# dashboard (Server → Webhooks → Add webhook, trigger: Bounce) as:
#   https://<user>:<password>@<your-domain>/api/webhooks/postmark/bounce
POSTMARK_WEBHOOK_USERNAME=""
POSTMARK_WEBHOOK_PASSWORD=""
