    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.14",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
